# AgentVerse environment variables.
# Copy this file to `.env.local` for local development.
# Per cao-integration/spec.md, the base URL is evaluated once at SPA bootstrap.

# CAO server base URL (HTTP/REST). Default: http://127.0.0.1:9889.
VITE_CAO_BASE_URL=http://127.0.0.1:9889

# Allow Canvas2D fallback for the terminal in dev when WebGL initialization fails.
# Production builds MUST refuse Canvas2D fallback (design D7).
VITE_ALLOW_CANVAS2D=false
