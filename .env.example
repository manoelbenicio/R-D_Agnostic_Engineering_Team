# AgentVerse environment variables.
# Copy this file to `.env.local` for local development.

# GO Core Server endpoint (HTTP/REST). Default: http://127.0.0.1:8080 (local).
# CRIT-003.13: replaces legacy VITE_CAO_BASE_URL
VITE_GO_CORE_BASE_URL=http://127.0.0.1:8080

# Allow Canvas2D fallback for the terminal in dev when WebGL initialization fails.
# Production builds MUST refuse Canvas2D fallback (design D7).
VITE_ALLOW_CANVAS2D=false

# ─── Auth ──────────────────────────────────────────────────────────────────
# Set to "firebase" to enable Firebase Auth (Google sign-in). Leave unset or
# set to "none" to run AgentVerse without authentication.
VITE_AUTH_PROVIDER=none

# When true, the SPA forces unauthenticated users to /login. When false,
# unauthenticated users can browse the UI but write/deploy actions may be
# rejected by the runtime in cloud mode.
VITE_AUTH_REQUIRED=false

# Firebase web app config. Required only when VITE_AUTH_PROVIDER=firebase.
# These values are PUBLIC by design — they ship in client-side JS — so
# committing them is safe. Get them from console.firebase.google.com →
# Project settings → General → Your apps → Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ─── Cloud Run preset (optional) ───────────────────────────────────────────
# When set, the Settings → General "Cloud (Run)" preset button fills the
# Runtime Base URL with this value. Otherwise the button warns the user.
# Populated automatically by scripts/deploy-cloud.sh after a deploy.
VITE_CLOUD_RUNTIME_URL=
ZENMUX_API_KEY=sk-ai-v1-b412f573fdb05ec72ff03cd071ada372d779fb7a78eaed332dbf0e489ce217df
