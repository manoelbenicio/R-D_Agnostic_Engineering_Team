{
  "uid": "multica-agents-tasks",
  "title": "Multica — Agents & Tasks",
  "tags": ["multica", "rpp", "agents"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Tasks Running",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(multica_agent_task_running)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 2, "type": "stat", "title": "Tasks Queued",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(multica_agent_task_queued)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 3, "type": "stat", "title": "Tasks Failed (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(multica_agent_task_failed_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 4, "type": "stat", "title": "Tasks Stuck (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "orange", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(multica_agent_task_stuck_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Agent tasks — running vs queued",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(multica_agent_task_running)", "legendFormat": "running", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(multica_agent_task_queued)", "legendFormat": "queued", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Task failures — rate (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(multica_agent_task_failed_total[5m]))", "legendFormat": "failed/s", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 7, "type": "stat", "title": "Active Users",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [ { "refId": "A", "expr": "sum(multica_active_users)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 8, "type": "stat", "title": "Active Workspaces",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "targets": [ { "refId": "A", "expr": "sum(multica_active_workspaces)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 9, "type": "stat", "title": "Daemon WS connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [ { "refId": "A", "expr": "sum(multica_daemonws_active_connections)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 10, "type": "stat", "title": "Backend up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "up{job=\"credential-service\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    }
  ]
}
