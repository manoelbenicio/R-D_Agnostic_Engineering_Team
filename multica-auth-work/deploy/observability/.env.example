# Config NAO-SEGRETA do stack de observabilidade. Copie para .env e ajuste.
# Segredos NUNCA aqui — eles vivem em ./secrets/ (docker secrets).

# Alvo do Postgres do produto para o postgres-exporter.
# Padrao: Postgres publicado no host (host.docker.internal).
# Se o Postgres roda no compose do produto (rede multica_default), use:
#   PG_HOST=postgres:5432
PG_HOST=host.docker.internal:5432
PG_DB=multica
PG_SSLMODE=disable

# Retencao do TSDB do Prometheus.
PROM_RETENTION=15d
