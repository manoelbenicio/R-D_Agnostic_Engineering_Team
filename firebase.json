{
  "$schema": "https://firebase.google.com/schema/firebase.json",
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/mockServiceWorker.js"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|woff2|woff|ttf|otf|svg|png|jpg|jpeg|webp|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(html|json|webmanifest)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate, max-age=0" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "Permissions-Policy", "value": "geolocation=(), camera=(), microphone=(self)" }
        ]
      }
    ]
  }
}
