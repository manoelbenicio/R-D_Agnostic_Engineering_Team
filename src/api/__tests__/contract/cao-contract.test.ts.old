import { describe, expect, it } from 'vitest';
import { CaoClient } from '@/api/cao-client';
import type { AgentProfile, Flow, InboxMessage, Session, Terminal } from '@/api/types';

const runContract = process.env.CAO_LIVE === '1' ? describe : describe.skip;
const client = new CaoClient();
const unique = `agentverse-contract-${Date.now()}`;
const workingDirectory = process.cwd();

runContract('CAO live contract', () => {
  it('asserts the response shape for every CAO v1 endpoint', async () => {
    expect(await client.getHealth()).toEqual({ status: 'ok' });

    const installedProfile = await client.installProfile(contractProfileMarkdown(unique));
    expectAgentProfile(installedProfile);

    const profiles = await client.listProfiles();
    expect(Array.isArray(profiles)).toBe(true);
    profiles.forEach(expectAgentProfile);

    expectAgentProfile(await client.getProfile(installedProfile.name));

    const providers = await client.listProviders();
    expect(Array.isArray(providers)).toBe(true);
    providers.forEach((provider) => {
      expect(provider).toEqual({
        name: expect.any(String),
        installed: expect.any(Boolean),
      });
    });

    const session = await client.createSession({
      profile: installedProfile.name,
      provider: 'codex',
      working_directory: workingDirectory,
    });
    expectSession(session);

    const sessions = await client.listSessions();
    expect(Array.isArray(sessions)).toBe(true);
    sessions.forEach(expectSession);

    expectSession(await client.getSession(session.name));

    const terminal = await client.addTerminalToSession(session.name, {
      profile: installedProfile.name,
      provider: 'codex',
      working_directory: workingDirectory,
    });
    expectTerminal(terminal);

    const terminals = await client.listTerminalsInSession(session.name);
    expect(Array.isArray(terminals)).toBe(true);
    terminals.forEach(expectTerminal);

    expectTerminal(await client.getTerminal(terminal.id));
    expect(await client.getTerminalOutput(terminal.id, 'tail')).toEqual(expect.any(String));
    expect(await client.getTerminalWorkingDirectory(terminal.id)).toEqual(expect.any(String));
    expect(await client.getTerminalMemoryContext(terminal.id)).toEqual(expect.any(String));

    await expect(client.sendTerminalInput(terminal.id, 'contract input')).resolves.toBeUndefined();
    await expect(client.exitTerminal(terminal.id)).resolves.toBeUndefined();

    const inboxMessage = await client.sendInboxMessage(terminal.id, 'contract inbox message');
    expectInboxMessage(inboxMessage);

    const inboxMessages = await client.listInboxMessages(terminal.id, { limit: 10 });
    expect(Array.isArray(inboxMessages)).toBe(true);
    inboxMessages.forEach(expectInboxMessage);

    const flow = await client.createFlow(contractFlow(unique, installedProfile.name));
    expectFlow(flow);

    const flows = await client.listFlows();
    expect(Array.isArray(flows)).toBe(true);
    flows.forEach(expectFlow);

    expectFlow(await client.getFlow(flow.name));
    await expect(client.enableFlow(flow.name)).resolves.toBeUndefined();
    await expect(client.disableFlow(flow.name)).resolves.toBeUndefined();
    await expect(client.runFlow(flow.name)).resolves.toBeUndefined();
    await expect(client.deleteFlow(flow.name)).resolves.toBeUndefined();

    const agentDirs = await client.getAgentDirs();
    expect(agentDirs).toEqual({ dirs: expect.any(Array) });
    agentDirs.dirs.forEach((dir) => expect(dir).toEqual(expect.any(String)));

    const updatedDirs = await client.setAgentDirs(agentDirs.dirs);
    expect(updatedDirs).toEqual({ dirs: expect.any(Array) });

    expect(await client.getSkill('gsd-help')).toEqual(expect.any(String));

    await expect(client.deleteTerminal(terminal.id)).resolves.toBeUndefined();
    await expect(client.deleteSession(session.name)).resolves.toBeUndefined();
  });
});

function contractProfileMarkdown(name: string): string {
  return `---\nname: ${name}\nrole: Contract\nprovider: openai\n---\nYou are a contract test profile.`;
}

function contractFlow(name: string, profileName: string): Flow {
  return {
    name,
    schedule: '0 3 * * *',
    agent_profile: profileName,
    provider: 'openai',
    prompt_template: 'Run the contract check.',
    enabled: false,
    last_run: null,
    next_run: null,
    gating_script: null,
  };
}

function expectAgentProfile(profile: AgentProfile): void {
  expect(profile).toEqual(
    expect.objectContaining({
      name: expect.any(String),
      role: expect.any(String),
      provider: expect.any(String),
    })
  );
}

function expectSession(session: Session): void {
  expect(session).toEqual(
    expect.objectContaining({
      name: expect.any(String),
      profile: expect.any(String),
      working_directory: expect.any(String),
      status: expect.any(String),
    })
  );
}

function expectTerminal(terminal: Terminal): void {
  expect(terminal).toEqual(
    expect.objectContaining({
      id: expect.any(String),
      profile: expect.any(String),
      status: expect.any(String),
      working_directory: expect.any(String),
    })
  );
}

function expectInboxMessage(message: InboxMessage): void {
  expect(message).toEqual(
    expect.objectContaining({
      id: expect.any(String),
      terminal_id: expect.any(String),
      message: expect.any(String),
      status: expect.any(String),
      created_at: expect.any(String),
    })
  );
}

function expectFlow(flow: Flow): void {
  expect(flow).toEqual(
    expect.objectContaining({
      name: expect.any(String),
      schedule: expect.any(String),
      agent_profile: expect.any(String),
      provider: expect.any(String),
      prompt_template: expect.any(String),
      enabled: expect.any(Boolean),
    })
  );
}
